# Mogbot — Local Development
# Copy to .env.local and fill in your API key.
# Start with: docker-compose up  (or: ENV=local docker-compose up)

ANTHROPIC_API_KEY=sk-ant-your-key-here
DATABASE_URL=postgresql://mogbot:mogbot@localhost:5432/mogbot
HOST=0.0.0.0
PORT=8000
WORKSPACE_DIR=./workspace
DEFAULT_MODEL=claude-sonnet-4-20250514
USD_TO_CAD_RATE=1.36
