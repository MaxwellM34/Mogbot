# Mogbot — Cloud / Production
# Copy to .env.cloud and fill in your values.
# Start with: ENV=cloud docker-compose up

ANTHROPIC_API_KEY=sk-ant-your-production-key-here
DATABASE_URL=postgresql://mogbot:CHANGE_ME_STRONG_PASSWORD@your-db-host:5432/mogbot
HOST=0.0.0.0
PORT=8000
WORKSPACE_DIR=/app/workspace
DEFAULT_MODEL=claude-sonnet-4-20250514
USD_TO_CAD_RATE=1.36
